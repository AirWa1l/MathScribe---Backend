# ─── Aplicación ────────────────────────────────────────────────
APP_NAME=MathScribe API
ENVIRONMENT=development
DEBUG=true
API_V1_PREFIX=/api/v1
# Orígenes permitidos para CORS (separados por coma)
CORS_ORIGINS=http://localhost:5173

# ─── Base de datos ─────────────────────────────────────────────
DATABASE_URL=postgresql+psycopg://mathscribe:mathscribe@localhost:5432/mathscribe

# ─── Autenticación ─────────────────────────────────────────────
JWT_SECRET=change-me
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# ─── Capa de inteligencia ──────────────────────────────────────
# Proveedor de reconocimiento por defecto: gemini | openai | mathpix
RECOGNITION_PROVIDER=gemini
GEMINI_API_KEY=
OPENAI_API_KEY=
MATHPIX_APP_ID=
MATHPIX_APP_KEY=

# ─── Almacenamiento de objetos (S3) ────────────────────────────
S3_ENDPOINT=
S3_BUCKET=mathscribe-uploads
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_REGION=us-east-1
